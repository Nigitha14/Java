//leap or not

import java.util.*;
class Main{
    static void leap(int a){
        if((a%4==0 || a%400==0) && a%100!=0){
            System.out.println("Leap Year");
        }
        else{
            System.out.println("Not Leap Year");
        }
    }
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int a=sc.nextInt();
        leap(a);
    }
}
        
