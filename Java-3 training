//Print 0 at last

import java.util.*;
public class Main{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int c=0;
        String r=" ";
        while(n>0){
            int d=n%10;
            if(d==0){
                c++;
            }
            else{
                r=d+r;
            }
            n=n/10;
        }
        System.out.print(r);
        for(int i=0;i<c;i++){
            System.out.print("0");
        }
    }
}
       
