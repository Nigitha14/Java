//Railway inheritence

import java.util.*;
class RailwayTicket{
    String pn;
    int a;
    double d;
    RailwayTicket(String pn,int a,double d){
        this.pn=pn;
        this.a=a;
        this.d=d;
    }
    double calculateFare(){
        double fare=d*2;
        if(a>=60){
            fare=fare-(fare*0.30);
        }
        return fare;
    }
    void show(){
        System.out.println(pn);
        System.out.println(a);
        System.out.println(d);
        System.out.println(calculateFare());
    }
}
public class Main{
    public static void main(String[]args){
        RailwayTicket r=new RailwayTicket("Nigitha",65,200);
        r.show();
    }
}
    
