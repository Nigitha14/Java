//Salary inheritence

import java.util.*;
class Employee{
    int eid;
    String en;
    Employee(int eid,String en){
        this.eid=eid;
        this.en=en;
    }
}
class Salary extends Employee{
    double bs;
    Salary(int eid,String en,double bs){
        super(eid,en);
        this.bs=bs;
    }
    double CNS(){
        double hra=bs*0.20;
        double da=bs*0.10;
        double pf=bs*0.05;
        return bs+hra+da-pf;
    }
    void display(){
        System.out.println(eid);
        System.out.println(en);
        System.out.println(bs);
        System.out.println(CNS());
    }
}
public class Main{
    public static void main(String[]args){
        Salary s=new Salary(101,"Nigitha",300000);
        s.display();
    }
}

