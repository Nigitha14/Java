import java.util.*;
class Employee{
    int employeeId;
    String employeename;
    double basicSalary;
    Employee(int employeeId,String employeename,double basicSalary){
        this.employeeId=employeeId;
        this.employeename=employeename;
        this.basicSalary=basicSalary;
    }
    double calculateHRA(){
        return basicSalary*0.20;
    }
    double calculateDA(){
        return basicSalary*0.10;
    }
    double calculatePF(){
        return basicSalary*0.05;
    }
    double calculateNetSalary(){
        return basicSalary+calculateHRA()+calculateDA()-calculatePF();
    }
    void display(){
        System.out.println(employeeId);
        System.out.println(employeename);
        System.out.println(basicSalary);
        System.out.println(calculateHRA());
        System.out.println(calculateDA());
        System.out.println(calculatePF());
        System.out.println(calculateNetSalary());
    }
}
public class Main{
    public static void main(String[]args){
        Employee e=new Employee(101,"Nigitha",30000);
        e.display();
    }
}
    
